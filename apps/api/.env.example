# Copy this file to apps/api/.env for local runtime configuration.
# Leave LLM_BASE_URL or LLM_API_KEY unset to keep deterministic catalog answers.
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your-api-key
# Optional LLM overrides.
# LLM_MODEL=gpt-4o-mini
# LLM_TIMEOUT_SECONDS=10
# Required runtime PostgreSQL URL for /chat, Alembic, and product catalog feed commands.
# PRODUCT_CATALOG_DATABASE_URL=postgresql+asyncpg://<user>:<password>@example.test:5432/catalog
