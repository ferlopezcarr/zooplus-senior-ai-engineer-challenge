# Copy this file to apps/api/.env for local runtime configuration.
# Leave LLM_BASE_URL or LLM_API_KEY unset to keep deterministic catalog answers.
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your-api-key
# Optional LLM overrides.
# LLM_MODEL=gpt-4o-mini
# LLM_TIMEOUT_SECONDS=10
# CATALOG_DATASET_PATH=../../data/product_catalog_dataset.json
# Local PostgreSQL URL for Alembic and product catalog feed commands.
# PRODUCT_CATALOG_DATABASE_URL=postgresql+asyncpg://local_user:local_password@127.0.0.1:5432/local_db
